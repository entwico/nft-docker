{
  "name": "@entwico/nft-docker",
  "version": "1.1.2",
  "packageManager": "pnpm@10.32.1",
  "description": "NFT-based Docker optimization for Node.js apps",
  "license": "MIT",
  "author": "admin@entwico.com",
  "type": "module",
  "bin": {
    "nft-docker": "./dist/cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/nft-docker.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "pnpm test:unit && pnpm test:sample:astro && pnpm test:sample:node",
    "test:unit": "vitest run --exclude='**/tests/samples/**'",
    "test:sample:astro": "pnpm -C samples/astro-app install && pnpm -C samples/astro-app build && vitest run tests/samples/astro.test.ts tests/samples/astro-rewrite.test.ts",
    "test:sample:node": "pnpm -C samples/node-app install && pnpm -C samples/node-app build && vitest run tests/samples/node.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm test",
    "changeset": "changeset",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@vercel/nft": "^1.4.0",
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.4",
    "rolldown": "^1.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/"
  ]
}
