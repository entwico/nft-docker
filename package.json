{
  "name": "@entwico/nft-docker",
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "NFT-based Docker optimization for Node.js apps",
  "license": "MIT",
  "author": "admin@entwico.com",
  "type": "module",
  "bin": {
    "nft-docker": "./dist/cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/entwico/nft-docker.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm test",
    "semantic-release": "semantic-release"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@vercel/nft": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ]
}
